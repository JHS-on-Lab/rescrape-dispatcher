# ----------------------------------------------------------------
# .dockerignore — docker build 컨텍스트에서 제외할 파일 목록.
# ----------------------------------------------------------------

# 환경별 접속 정보 — 컨테이너 실행 시 --env-file 로 주입
.env.*

# 가상환경
.venv/
venv/

# Python 바이트코드 캐시
__pycache__/
*.py[cod]

# 버전 관리
.git/
.gitignore

# 배포 스크립트 — 이미지 안에서 실행할 파일이 아님
deploy/

# 테스트·진단 스크립트
scripts/

# 개발 도구
docs/
.claude/
.vscode/
.idea/

# 실행 중 생성되는 산출물
logs/
*.log
