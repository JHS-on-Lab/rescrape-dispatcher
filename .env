# ================================================================
# 공통 기본값 — 민감 정보 없음. 환경별 접속 정보는 .env.{APP_ENV} 에 작성.
# 로컬 개인 설정은 .env.local (gitignore 됨).
# ================================================================

# RDS — 환경별 파일(.env.dev / .env.prod)에서 반드시 override
# keyword-collector 와 같은 RDS에 접속한다.
RDS_HOST=
RDS_PORT=3306
RDS_USER=
RDS_PASSWORD=
RDS_DB=keyword_collector

# Worker
WORKER_ID=rescrape-1

# Solr — 조회 대상 Solr (keyword-collector 가 수집 결과를 저장하는 코어)
SOLR_URL=http://localhost:8983/solr/news
HTTP_VERIFY_SSL=true

# Solr 재수집 조건 쿼리
# SOLR_RESCRAPE_QUERY: Solr q 파라미터 (기본: 전체)
# SOLR_RESCRAPE_FQ:    Solr fq 파라미터 (기본: 없음, 예: collected_at:[* TO NOW-7DAYS])
SOLR_RESCRAPE_QUERY=*:*
SOLR_RESCRAPE_FQ=

# Solr 조회 크기
SOLR_QUERY_BATCH_SIZE=100    # Solr 요청 1회당 rows
SOLR_RESCRAPE_MAX_DOCS=1000  # 디스패치 1사이클당 최대 URL 수

# Dispatch
DISPATCH_INTERVAL_SECONDS=3600   # 사이클 반복 주기 (초)
RESCRAPE_PRIORITY=5              # 재수집 URL 에 부여할 우선순위

# Logging
LOG_DIR=./logs
LOG_LEVEL=INFO
LOG_ROTATION=daily
HEARTBEAT_INTERVAL_SECONDS=60
