# ================================================================
# 공통 기본값 — 민감 정보 없음. 환경별 접속 정보는 .env.{APP_ENV} 에 작성.
# 로컬 개인 설정은 .env.local (gitignore 됨).
# ================================================================

# RDS — 환경별 파일(.env.dev / .env.prod) 또는 .env.local 에서 반드시 override
RDS_HOST=
RDS_PORT=3306
RDS_USER=
RDS_PASSWORD=
RDS_DB=crawlerdb

# Worker
WORKER_ID=rescrape-1

# Solr 접속 모드 (둘 중 하나만 활성화)
# [직접 모드] SOLR_URL 에 값을 입력하면 해당 URL 로 직접 접속하며, 아래 파라미터를 사용한다.
# [DB 조회 모드] SOLR_URL 을 비워두면 DI_* 조건으로 trendtracker.t_di_config_v1 에서 모든 설정을 가져온다.
SOLR_URL=
SOLR_QUERY=*:*
SOLR_FILTER_QUERY=
SLIDING_WINDOW_MINUTES=30    # 슬라이딩 윈도우 크기(분) — 직접 모드 전용
SOLR_MAX_DOCS=1000           # 최대 조회 수 — 직접 모드 전용

# DB 조회 모드 조건 (SOLR_URL 비워둔 경우에만 사용)
# WHERE tnt_id = DI_TNT_ID AND project_id = DI_PROJECT_ID AND di_server_ip = DI_SERVER_IP
DI_TNT_ID=
DI_PROJECT_ID=
DI_SERVER_IP=
TRENDTRACKER_DB=trendtracker
HTTP_VERIFY_SSL=true

# Solr 요청 1회당 rows (직접/DB 모드 공통)
SOLR_QUERY_BATCH_SIZE=100

# Dispatch
DISPATCH_INTERVAL_SECONDS=300    # 사이클 반복 주기 (초). 기본 5분
RESCRAPE_PRIORITY=5              # 투입 URL 에 부여할 우선순위

# Logging
LOG_DIR=./logs
LOG_LEVEL=INFO
LOG_ROTATION=daily
HEARTBEAT_INTERVAL_SECONDS=60
