# ================================================================
# 공통 기본값 — 민감 정보 없음. 환경별 접속 정보는 .env.{APP_ENV} 에 작성.
# 로컬 개인 설정은 .env.local (gitignore 됨).
# ================================================================

# RDS — 환경별 파일(.env.dev / .env.prod)에서 반드시 override
# keyword-crawler 와 같은 RDS에 접속한다.
RDS_HOST=
RDS_PORT=3306
RDS_USER=
RDS_PASSWORD=
RDS_DB=keyword_crawler

# Worker
WORKER_ID=rescrape-1

# Solr — 조회 대상 Solr (keyword-crawler 가 수집 결과를 저장하는 코어)
SOLR_URL=http://localhost:8983/solr/news
HTTP_VERIFY_SSL=true

# Solr 조회 조건
# SOLR_RESCRAPE_QUERY: Solr q 파라미터 (기본: 전체)
SOLR_RESCRAPE_QUERY=*:*
# URL contains 필터 — 쉼표로 구분된 패턴 목록 (OR 결합). 예: naver.com,daum.net
# 비어있으면 전체 URL 대상.
SOLR_RESCRAPE_URL_CONTAINS=

# 슬라이딩 윈도우 — 매 사이클마다 최근 N분 이내 수집된 문서를 조회한다.
# DISPATCH_INTERVAL_SECONDS 의 2배 권장. 예: 주기 5분 → 윈도우 10분.
SLIDING_WINDOW_MINUTES=10

# Solr 조회 크기
SOLR_QUERY_BATCH_SIZE=100    # Solr 요청 1회당 rows
SOLR_RESCRAPE_MAX_DOCS=1000  # 디스패치 1사이클당 최대 URL 수

# Dispatch
DISPATCH_INTERVAL_SECONDS=300    # 사이클 반복 주기 (초). 기본 5분
RESCRAPE_PRIORITY=5              # 투입 URL 에 부여할 우선순위

# Logging
LOG_DIR=./logs
LOG_LEVEL=INFO
LOG_ROTATION=daily
HEARTBEAT_INTERVAL_SECONDS=60
