# ================================================================
# 공통 기본값 — 변경이 없는 값은 여기서만 정의한다.
# 환경별로 달라지는 값은 .env.{APP_ENV} 에서만 설정한다.
# ================================================================

# Solr 접속 모드
# SOLR_DIRECT_ENABLED=true → SOLR_URL 과 아래 파라미터로 직접 접속
# SOLR_DIRECT_ENABLED=false → DI_* 조건으로 t_di_config_v1 에서 모두 조회
SOLR_DIRECT_ENABLED=false
SOLR_URL=
SOLR_QUERY=*:*
SOLR_FILTER_QUERY=
SLIDING_WINDOW_MINUTES=30
SOLR_MAX_DOCS=1000
SOLR_QUERY_BATCH_SIZE=100

DI_TNT_ID=
DI_PROJECT_ID=
DI_SERVER_IP=

HTTP_VERIFY_SSL=true

# Dispatch
DISPATCH_INTERVAL_SECONDS=300
RESCRAPE_PRIORITY=5

# Logging
LOG_DIR=./logs
LOG_LEVEL=INFO
LOG_ROTATION=daily
LOG_RETAIN_DAYS=30    # daily 모드: 며칠치 보관 (기본 30)
LOG_BACKUP_COUNT=10   # size 모드: 파일 몇 개 보관 (기본 10)
HEARTBEAT_INTERVAL_SECONDS=60
