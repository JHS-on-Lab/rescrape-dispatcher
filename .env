# ================================================================
# 공통 기본값 — 민감 정보 없음. 환경별 접속 정보는 .env.{APP_ENV} 에 작성.
# 로컬 개인 설정은 .env.local (gitignore 됨).
# ================================================================

# RDS — 환경별 파일(.env.dev / .env.prod)에서 반드시 override
# keyword-crawler 와 같은 RDS에 접속한다.
RDS_HOST=
RDS_PORT=3306
RDS_USER=
RDS_PASSWORD=
RDS_DB=keyword_crawler

# Worker
WORKER_ID=rescrape-1

# Solr 접속 정보 — trendtracker.t_di_config_v1 조회 조건
# WHERE tnt_id = DI_TNT_ID AND project_id = DI_PROJECT_ID AND di_server_ip = DI_SERVER_IP
DI_TNT_ID=
DI_PROJECT_ID=
DI_SERVER_IP=
TRENDTRACKER_DB=trendtracker
HTTP_VERIFY_SSL=true

# Solr 조회 크기 — 나머지 파라미터(q / fq / window / max)는 t_di_config_v1 에서 조회
SOLR_QUERY_BATCH_SIZE=100    # Solr 요청 1회당 rows

# Dispatch
DISPATCH_INTERVAL_SECONDS=300    # 사이클 반복 주기 (초). 기본 5분
RESCRAPE_PRIORITY=5              # 투입 URL 에 부여할 우선순위

# Logging
LOG_DIR=./logs
LOG_LEVEL=INFO
LOG_ROTATION=daily
HEARTBEAT_INTERVAL_SECONDS=60
