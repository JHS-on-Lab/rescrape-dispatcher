# ================================================================
# 공통 기본값 — 변경이 없는 값은 여기서만 정의한다.
# 환경별로 달라지는 값은 .env.{APP_ENV} 에서만 설정한다.
# 로컬 개인 설정은 .env.local (gitignore 대상).
# ================================================================

# RDS — 접속 정보는 환경별 파일에서 주입
RDS_PORT=3306
RDS_CRAWLER_DB=crawlerdb
RDS_TRENDTRACKER_DB=trendtracker

# Solr 접속 모드
# [직접 모드] SOLR_URL 설정 시 아래 파라미터 사용
# [DB 조회 모드] SOLR_URL 비워두면 DI_* 조건으로 t_di_config_v1 에서 모두 조회
SOLR_URL=
SOLR_QUERY=*:*
SOLR_FILTER_QUERY=
SLIDING_WINDOW_MINUTES=30
SOLR_MAX_DOCS=1000
SOLR_QUERY_BATCH_SIZE=100
DI_TNT_ID=
DI_PROJECT_ID=
DI_SERVER_IP=
HTTP_VERIFY_SSL=true

# Dispatch
DISPATCH_INTERVAL_SECONDS=300
RESCRAPE_PRIORITY=5

# Logging
LOG_DIR=./logs
LOG_LEVEL=INFO
LOG_ROTATION=daily
HEARTBEAT_INTERVAL_SECONDS=60
