# ================================================================
# dev 환경 설정 — APP_ENV=dev 일 때 .env 위에 override
# dev 서버는 VPC 내부이므로 SSH 터널 불필요
# ================================================================

TUNNEL_ENABLED=false

# RDS — dev RDS 직접 접속
RDS_HOST=dev-shared-rds.cdaao0ik8058.ap-northeast-2.rds.amazonaws.com
RDS_PORT=3306
RDS_USER=admin
RDS_PASSWORD=thswhdgus1!
RDS_DB=crawlerdb

# Solr — dev 에서는 범위를 좁혀 테스트 (직접 모드 or DI_* 채워서 DB 조회 모드)
SLIDING_WINDOW_MINUTES=10
SOLR_MAX_DOCS=100

HTTP_VERIFY_SSL=false
WORKER_ID=rescrape-dev-1
