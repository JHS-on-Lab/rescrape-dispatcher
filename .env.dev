# ================================================================
# dev 환경 설정 — APP_ENV=dev 일 때 .env 위에 override
# ================================================================

# RDS — dev RDS 접속 정보
RDS_HOST=
RDS_PORT=3306
RDS_USER=
RDS_PASSWORD=
RDS_DB=keyword_crawler

# Solr
SOLR_URL=http://localhost:8983/solr/news
HTTP_VERIFY_SSL=false

# dev 에서는 범위를 좁혀 테스트
SLIDING_WINDOW_MINUTES=10
SOLR_RESCRAPE_MAX_DOCS=100

WORKER_ID=rescrape-dev-1
