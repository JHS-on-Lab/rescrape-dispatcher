# ================================================================
# prod 환경 설정 — APP_ENV=prod 일 때 .env 위에 override
# ================================================================

# RDS — prod RDS 접속 정보
RDS_HOST=
RDS_PORT=3306
RDS_USER=
RDS_PASSWORD=
RDS_DB=crawlerdb

# Solr
SOLR_URL=http://solr:8983/solr/news

# 슬라이딩 윈도우 — 주기(DISPATCH_INTERVAL_SECONDS)의 2배 권장
SLIDING_WINDOW_MINUTES=10
SOLR_RESCRAPE_MAX_DOCS=5000

DISPATCH_INTERVAL_SECONDS=300
WORKER_ID=rescrape-prod-1
