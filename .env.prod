# ================================================================
# prod 환경 설정 — APP_ENV=prod 일 때 .env 위에 override
# ================================================================

# RDS — prod RDS 접속 정보
RDS_HOST=
RDS_PORT=3306
RDS_USER=
RDS_PASSWORD=
RDS_DB=keyword_collector

# Solr
SOLR_URL=http://solr:8983/solr/news

# 재수집 조건
SOLR_RESCRAPE_FQ=collected_at:[* TO NOW-7DAYS]
SOLR_RESCRAPE_MAX_DOCS=5000

DISPATCH_INTERVAL_SECONDS=3600
WORKER_ID=rescrape-prod-1
